[Unit]
Description=Dauerwelle Screen Client
After=network-online.target graphical.target
Wants=network-online.target

[Service]
Type=forking
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
WorkingDirectory=/home/pi/client
ExecStart=/usr/bin/tmux new-session -d -s dauerwelle 'node /home/pi/client/client-pi.js'
ExecStop=/usr/bin/tmux kill-session -t dauerwelle
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
