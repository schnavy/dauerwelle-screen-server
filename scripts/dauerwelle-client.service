[Unit]
Description=Dauerwelle Screen Client
After=network-online.target graphical.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
WorkingDirectory=/home/pi/client
ExecStart=/usr/bin/node /home/pi/client/client-pi.js
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
